# Core behavior
TIMEZONE=Asia/Singapore
TOP_N=5
REQUEST_TIMEOUT=15
REQUEST_RETRIES=2
SEMANTIC_TIMEOUT=240
CODEX_MODEL=

# Source RSS/API endpoints (official/public only)
GOOGLE_NEWS_RSS=https://news.google.com/rss?hl=en-SG&gl=SG&ceid=SG:en
CNA_RSS=https://www.channelnewsasia.com/api/v1/rss-outbound-feed?_format=xml&category=10416
ST_RSS=https://www.straitstimes.com/news/singapore/rss.xml
# Zaobao direct RSS endpoints are not consistently public; default to Google News site feed.
ZAOBAO_RSS=https://news.google.com/rss/search?q=site:zaobao.com.sg&hl=zh-SG&gl=SG&ceid=SG:zh-Hans
